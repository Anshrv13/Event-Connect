    <h2 class="text-2xl font-bold mb-8">Featured Events</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white rounded-lg shadow-sm">
        <div class="h-48 bg-neutral-300 rounded-t-lg flex items-center justify-center">
          <span class="text-white">Event Image</span>
        </div>
        <div class="p-4">
          <h3 class="font-bold mb-2">Music Festival 2025</h3>
          <p class="text-neutral-600 text-sm mb-4">Los Angeles, CA</p>
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium">Mar 15, 2025</span>
            <button class="px-4 py-2 border border-neutral-300 rounded-lg text-sm">Details</button>
          </div>
        </div>
      </div>
