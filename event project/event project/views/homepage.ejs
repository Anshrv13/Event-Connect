          </div>
          <button class="px-4 py-2 border border-neutral-300 rounded-lg">Apply Now</button>
        </div>
      </div>
      <div class="bg-white p-6 rounded-lg shadow-sm">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-bold mb-2">Production Assistant</h3>
            <p class="text-neutral-600 mb-2">EventPro • Miami, FL</p>
            <div class="flex gap-2">
              <span class="px-3 py-1 bg-neutral-100 rounded-full text-sm">Contract</span>
              <span class="px-3 py-1 bg-neutral-100 rounded-full text-sm">On-site</span>
            </div>
          </div>
          <button class="px-4 py-2 border border-neutral-300 rounded-lg">Apply Now</button>
        </div>
      </div>
    </div>
  </div>
</section>
