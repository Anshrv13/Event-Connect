          <span class="text-white">Event Image</span>
        </div>
        <div class="p-4">
          <h3 class="font-bold mb-2">Tech Conference 2025</h3>
          <p class="text-neutral-600 text-sm mb-4">San Francisco, CA</p>
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium">Apr 20, 2025</span>
            <button class="px-4 py-2 border border-neutral-300 rounded-lg text-sm">Details</button>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-lg shadow-sm">
        <div class="h-48 bg-neutral-300 rounded-t-lg flex items-center justify-center">
          <span class="text-white">Event Image</span>
        </div>
        <div class="p-4">
          <h3 class="font-bold mb-2">Food &amp; Wine Festival</h3>
          <p class="text-neutral-600 text-sm mb-4">New York, NY</p>
          <div class="flex items-center justify-between">
            <span class="text-sm font-medium">May 10, 2025</span>
            <button class="px-4 py-2 border border-neutral-300 rounded-lg text-sm">Details</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<section id="job-opportunities" class="py-16 bg-neutral-50">
  <div class="container mx-auto px-4">
    <h2 class="text-2xl font-bold mb-8">Latest Job Opportunities</h2>
    <div class="grid gap-4">
      <div class="bg-white p-6 rounded-lg shadow-sm">
        <div class="flex justify-between items-start">
          <div>
            <h3 class="font-bold mb-2">Event Coordinator</h3>
            <p class="text-neutral-600 mb-2">LiveNation • Los Angeles, CA</p>
            <div class="flex gap-2">
              <span class="px-3 py-1 bg-neutral-100 rounded-full text-sm">Full-time</span>
